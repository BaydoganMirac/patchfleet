{
  "name": "patchfleet",
  "version": "0.1.0",
  "description": "Local-first command center for Claude Code, Codex, and Gemini CLI.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/BaydoganMirac/patchfleet#readme",
  "bugs": "https://github.com/BaydoganMirac/patchfleet/issues",
  "keywords": [
    "ai-agents",
    "claude-code",
    "codex",
    "gemini-cli",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BaydoganMirac/patchfleet.git"
  },
  "bin": {
    "patchfleet": "bin/patchfleet.mjs"
  },
  "files": [
    ".next",
    "app",
    "bin",
    "docs/install.md",
    "extensions",
    "lib",
    "scripts",
    "middleware.js",
    "next.config.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node scripts/local-next.mjs dev",
    "build": "next build && node scripts/sanitize-package.mjs",
    "prepack": "npm run build",
    "start": "node scripts/local-next.mjs start",
    "test": "node --test --test-concurrency=1 tests/*.test.*",
    "test:package": "node smoke/package-smoke.mjs"
  },
  "dependencies": {
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
